{
  "displayName": "[Managed] Unexpected Error Spike",
  "documentation": {
    "content": "Unexpected client/server errors from request.summary logs crossed threshold.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "notificationChannels": [],
  "userLabels": {
    "managed_by": "repo_observability",
    "scope": "ops"
  },
  "conditions": [
    {
      "displayName": "obs_unexpected_error_count rate > 0.01 req/s (5m)",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND metric.type=\"logging.googleapis.com/user/obs_unexpected_error_count\"",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0.01,
        "duration": "300s",
        "trigger": {
          "count": 1
        }
      }
    }
  ]
}
