{
  "displayName": "[Managed] Backend 5xx Rate High",
  "documentation": {
    "content": "Backend 5xx rate crossed threshold for consent-protocol.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "notificationChannels": [],
  "userLabels": {
    "managed_by": "repo_observability",
    "scope": "ops"
  },
  "conditions": [
    {
      "displayName": "consent-protocol 5xx rate > 0.02 req/s (5m)",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.label.\"service_name\"=\"__BACKEND_SERVICE__\" AND metric.type=\"run.googleapis.com/request_count\" AND metric.label.\"response_code_class\"=\"5xx\"",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0.02,
        "duration": "300s",
        "trigger": {
          "count": 1
        }
      }
    }
  ]
}
