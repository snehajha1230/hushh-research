{
  "displayName": "[Managed] Data Health Anomaly",
  "documentation": {
    "content": "Supabase data-health check reported one or more anomalies.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "notificationChannels": [],
  "userLabels": {
    "managed_by": "repo_observability",
    "scope": "data"
  },
  "conditions": [
    {
      "displayName": "obs_data_health_anomaly_count delta > 0",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_job\" AND metric.type=\"logging.googleapis.com/user/obs_data_health_anomaly_count\"",
        "aggregations": [
          {
            "alignmentPeriod": "900s",
            "perSeriesAligner": "ALIGN_DELTA",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0,
        "duration": "0s",
        "trigger": {
          "count": 1
        }
      }
    }
  ]
}
