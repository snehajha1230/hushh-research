# Frontend Environment Variables Template
# These are baked into the Docker image at build time

# ============================================================================
# FIREBASE CONFIGURATION (Public - Safe to Commit)
# ============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_firebase_web_push_vapid_key
# Optional analytics linkage (preferred for two-environment split)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_UAT=G-UATXXXXXXXX
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_STAGING=G-XXXXXXXXXX
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_PRODUCTION=G-YYYYYYYYYY

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend URL (Python FastAPI) — used by lib/api/consent.ts, lib/config.ts, api routes
# UPDATE with actual backend URL after backend deployment
NEXT_PUBLIC_BACKEND_URL=https://your-backend-host.run.app

# ============================================================================
# BUILD CONFIGURATION
# ============================================================================
CAPACITOR_BUILD=false
ENVIRONMENT_MODE=production
NEXT_PUBLIC_OBSERVABILITY_ENV=production
NEXT_PUBLIC_OBSERVABILITY_ENABLED=true
NEXT_PUBLIC_OBSERVABILITY_DEBUG=false
NEXT_PUBLIC_OBSERVABILITY_SAMPLE_RATE=1
NEXT_PUBLIC_GTM_ID_UAT=GTM-UATXXXX
NEXT_PUBLIC_GTM_ID_STAGING=GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID_PRODUCTION=GTM-YYYYYYY

# ============================================================================
# NOTES
# ============================================================================
# 1. These variables are baked into the static build at Docker build time
# 2. NEXT_PUBLIC_* variables are exposed to the browser
# 3. Never include secrets here - they will be visible in the browser
# 4. Firebase config is public and safe to commit
# 5. App review mode is backend runtime config (/api/app-config/review-mode)
# 6. Update NEXT_PUBLIC_BACKEND_URL with actual backend URL before building
