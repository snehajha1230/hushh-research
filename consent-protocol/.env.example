# consent-protocol/.env.example
# Copy to .env and replace placeholder values.
# Runtime profile workflow:
# - Bootstrap local runtime profile files from templates + cloud secrets:
#   bash ../scripts/env/bootstrap_profiles.sh
# - Canonical contributor runtime:
#   .env (local backend) + frontend mode files activated through scripts/env/use_profile.sh

# Server port (optional if not running web server)
PORT=3000

# HMAC signing key (64-character hex, 256-bit)
APP_SIGNING_KEY=your_local_hex_secret_here

# Vault AES encryption key (64-character hex, 256-bit)
VAULT_DATA_KEY=your_local_vault_hex_here

# Expiration durations (milliseconds)
DEFAULT_CONSENT_TOKEN_EXPIRY_MS=604800000
DEFAULT_TRUST_LINK_EXPIRY_MS=2592000000

# App context
APP_RUNTIME_PROFILE=local
ENVIRONMENT=development
AGENT_ID=agent_hushh_local
HUSHH_HACKATHON=enabled
OTEL_ENABLED=false

APP_FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Vault write client version gate
MIN_VAULT_WRITE_CLIENT_VERSION=2.0.0
ENFORCE_VAULT_WRITE_CLIENT_VERSION=true

# Optional override: comma-separated passkey RP IDs allowed by backend validation.
# If omitted, backend derives allowlist from APP_FRONTEND_ORIGIN + CORS_ALLOWED_ORIGINS.
# Set explicitly only when you need stricter/manual control.
# PASSKEY_ALLOWED_RP_IDS=localhost,127.0.0.1,kai.hushh.ai,uat.kai.hushh.ai

# Canonical structured runtime config used by hosted deploys.
# Local bootstrap regenerates this from the explicit runtime keys below.
BACKEND_RUNTIME_CONFIG_JSON=

# Supabase Session Pooler Connection
DB_USER=postgres.your_project_ref
DB_PASSWORD=replace_with_db_password
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_UNIX_SOCKET=
CLOUDSQL_INSTANCE_CONNECTION_NAME=
CLOUDSQL_PROXY_PORT=
# Optional: in development, allow backend startup even when the DB is offline.
# Production stays strict by default.
# REQUIRE_DATABASE_ON_STARTUP=false

# Google Generative AI / Vertex AI
GOOGLE_API_KEY=replace_with_google_api_key
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_GENAI_USE_VERTEXAI=True

# Optional: self-serve developer token for stdio MCP hosts and token-auth
# developer lookups. Contributors can leave this blank until they enable
# developer access from the Kai app.
HUSHH_DEVELOPER_TOKEN=
DEVELOPER_API_ENABLED=true
REMOTE_MCP_ENABLED=false
CONSENT_SSE_ENABLED=true
SYNC_REMOTE_ENABLED=false

FIREBASE_ADMIN_CREDENTIALS_JSON=__FIREBASE_ADMIN_CREDENTIALS_JSON__

FINNHUB_API_KEY=replace_with_finnhub_api_key

PMP_API_KEY=replace_with_pmp_api_key

NEWSAPI_KEY=

# Maintainer-only overlay keys such as app-review toggles, reviewer identities,
# and local test-user credentials belong in an untracked overlay file.

# Alpaca Broker API (embedded funding via Plaid processor token + ACH relationship)
# Set either:
# - ALPACA_BROKER_AUTH_TOKEN (raw token or already-prefixed Authorization value), OR
# - ALPACA_BROKER_KEY_ID + ALPACA_BROKER_SECRET (or APCA_* aliases)
ALPACA_ENV=sandbox
ALPACA_BROKER_ENV=sandbox
ALPACA_BROKER_BASE_URL=
ALPACA_BROKER_AUTH_TOKEN=
ALPACA_BROKER_KEY_ID=
ALPACA_BROKER_SECRET=
APCA_API_KEY_ID=
APCA_API_APP_SIGNING_KEY=
ALPACA_DEFAULT_ACCOUNT_ID=
# Dedicated envelope key for funding secrets (Plaid access token + processor token)
# If omitted, backend falls back to PLAID_ACCESS_TOKEN_KEY and then a derived key.
FUNDING_SECRET_ENCRYPTION_KEY=

# Legacy Alpaca aliases retained for compatibility
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Optional: Alpaca Connect OAuth (user signs in with Alpaca, backend auto-maps account_id)
# Required for "Connect Alpaca account" UX without manual UUID entry.
ALPACA_CONNECT_CLIENT_ID=
ALPACA_CONNECT_CLIENT_SECRET=
# Must be HTTPS and allowlisted in your Alpaca OAuth app settings.
ALPACA_CONNECT_REDIRECT_URI=
# Optional overrides (defaults are for Alpaca Connect production hostnames)
ALPACA_CONNECT_AUTHORIZE_URL=https://app.alpaca.markets/oauth/authorize
ALPACA_CONNECT_TOKEN_URL=https://api.alpaca.markets/oauth/token
ALPACA_CONNECT_ACCOUNT_URL=https://api.alpaca.markets/v2/account
ALPACA_CONNECT_SCOPES=account:write trading
# Optional explicit env sent to authorize endpoint: paper or live
ALPACA_CONNECT_ENV=
ALPACA_CONNECT_STATE_TTL_SECONDS=900

# Gmail-backed support messaging (profile bug reports / support requests)
# By default the backend can reuse FIREBASE_ADMIN_CREDENTIALS_JSON as the Gmail
# service account if that client is authorized for Workspace domain-wide
# delegation. Set SUPPORT_EMAIL_SERVICE_ACCOUNT_JSON only when you want a
# separate dedicated mailer service account. RIA invite emails reuse this same
# Gmail configuration and send investors into Kai with a branded join template.
SUPPORT_EMAIL_SERVICE_ACCOUNT_JSON=
SUPPORT_EMAIL_DELEGATED_USER=support@hushh.ai
SUPPORT_EMAIL_FROM=support@hushh.ai
SUPPORT_EMAIL_TO=support@hushh.ai
# In non-production you can route delivery to a developer inbox while keeping
# support@hushh.ai as the delegated sender identity.
SUPPORT_EMAIL_TEST_TO=
# Optional: set explicitly to live or test. If omitted, non-production defaults
# to test when SUPPORT_EMAIL_TEST_TO is present.
SUPPORT_EMAIL_MODE=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=
GMAIL_OAUTH_TOKEN_KEY=
KAI_GMAIL_RECEIPTS_SYNC_ENABLED=true
KAI_GMAIL_RECEIPTS_SYNC_LOOP_SECONDS=3600
KAI_GMAIL_RECEIPTS_DAILY_SYNC_HOURS=24
KAI_GMAIL_RECEIPTS_MAX_MESSAGES_PER_SYNC=300
GMAIL_RECEIPT_HTTP_TIMEOUT_SECONDS=25
GMAIL_RECEIPT_LLM_FALLBACK_ENABLED=false
GMAIL_RECEIPT_LLM_MODEL=gemini-2.5-flash-lite

# Voice / Realtime (OpenAI)
OPENAI_API_KEY=replace_with_openai_api_key
# Hosted deploys use this canonical structured runtime contract instead of
# dozens of per-flag env vars.
VOICE_RUNTIME_CONFIG_JSON={"realtime_enabled":true,"hosted_voice_enabled":true,"canary_percent":100,"tool_execution_disabled":false,"force_realtime":true,"fail_fast":true,"disable_fallbacks":true,"realtime_model":"gpt-realtime","stt_models":["gpt-4o-mini-transcribe","whisper-1"],"intent_models":["gpt-4.1-nano","gpt-4o-mini","gpt-4.1-mini"],"tts_models":["gpt-4o-mini-tts"],"tts_default_voice":"alloy","tts_format":"mp3","tts_prefer_quality":false}

# Plaid Investments (optional for Kai brokerage sync)
# Sandbox example:
# PLAID_ENV=sandbox
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# Webhook URL is not dashboard-allowlisted; it must be publicly reachable and is
# supplied by the backend during Link token creation.
# Local:  https://<your-tunnel>/api/kai/plaid/webhook
# UAT:    https://uat.kai.hushh.ai/api/kai/plaid/webhook
# Prod:   https://kai.hushh.ai/api/kai/plaid/webhook
# PLAID_WEBHOOK_URL=https://your-public-domain-or-tunnel/api/kai/plaid/webhook
# PLAID_REDIRECT_PATH=/kai/plaid/oauth/return
# Optional explicit override if you do not want APP_FRONTEND_ORIGIN + PLAID_REDIRECT_PATH:
# PLAID_REDIRECT_URI=http://localhost:3000/kai/plaid/oauth/return
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_CLIENT_NAME=Hushh Kai
PLAID_COUNTRY_CODES=US
PLAID_WEBHOOK_URL=
PLAID_REDIRECT_PATH=/kai/plaid/oauth/return
PLAID_REDIRECT_URI=
PLAID_ACCESS_TOKEN_KEY=
PLAID_TX_HISTORY_DAYS=730
PLAID_WEBHOOK_VERIFICATION_ENABLED=true
PLAID_WEBHOOK_MAX_SKEW_SECONDS=300
FUNDING_ACH_RELATIONSHIP_POLL_SECONDS=15
FUNDING_ACH_RELATIONSHIP_POLL_INTERVAL_SECONDS=2
FUNDING_TRANSFER_MAX_INCOMING_USD=250000
FUNDING_TRANSFER_MAX_OUTGOING_USD=250000
FUNDING_STALE_PENDING_SECONDS=172800
# Data health observability thresholds (Cloud Scheduler job)
OBS_DATA_STALE_RATIO_THRESHOLD=0.25

# Regulatory verification providers.
# Production advisory startup fails closed if IAPD is not configured.
# RIA intelligence verifier supports either:
# - base URL + endpoint path (defaults to /v1/ria/profile)
# - full verify URL override (for example /v1/ria/profile/stage1)
RIA_INTELLIGENCE_VERIFY_BASE_URL=
RIA_INTELLIGENCE_VERIFY_ENDPOINT_PATH=/v1/ria/profile
RIA_INTELLIGENCE_VERIFY_URL=
RIA_INTELLIGENCE_VERIFY_API_KEY=
RIA_INTELLIGENCE_VERIFY_TIMEOUT_SECONDS=25
IAPD_VERIFY_BASE_URL=
IAPD_VERIFY_API_KEY=
IAPD_VERIFY_TIMEOUT_SECONDS=5
BROKER_CAPABILITY_ENABLED=false
BROKER_VERIFY_BASE_URL=
BROKER_VERIFY_API_KEY=
BROKER_VERIFY_TIMEOUT_SECONDS=5
BROKER_PUBLIC_FALLBACK_ENABLED=false
