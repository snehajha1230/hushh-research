# Backend runtime profile: uat-remote
# Reference-only local copy of deployed UAT backend config. Not launched by default.

APP_RUNTIME_PROFILE=uat-remote
ENVIRONMENT=uat
PORT=8000
FRONTEND_URL=https://uat.kai.hushh.ai
CORS_ALLOWED_ORIGINS=https://uat.kai.hushh.ai,https://hushh-webapp-<uat-hash>-uc.a.run.app
PLAID_ENV=production
PLAID_CLIENT_ID=replace_with_plaid_client_id
PLAID_SECRET=replace_with_production_plaid_secret
PLAID_CLIENT_NAME=Hushh Kai
PLAID_COUNTRY_CODES=US
PLAID_WEBHOOK_URL=https://uat.kai.hushh.ai/api/kai/plaid/webhook
PLAID_REDIRECT_PATH=/kai/plaid/oauth/return
PLAID_TOKEN_ENCRYPTION_KEY=replace_with_shared_plaid_encryption_key
PLAID_TX_HISTORY_DAYS=730
GOOGLE_GENAI_USE_VERTEXAI=True
OTEL_ENABLED=false

SECRET_KEY=replace_with_uat_secret_key
VAULT_ENCRYPTION_KEY=__SET_VAULT_KEY__
FIREBASE_SERVICE_ACCOUNT_JSON=__FIREBASE_SERVICE_ACCOUNT_JSON__
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=__FIREBASE_AUTH_SERVICE_ACCOUNT_JSON__
APP_REVIEW_MODE=false
REVIEWER_UID=replace_with_reviewer_uid_if_used
MCP_DEVELOPER_TOKEN=replace_with_uat_mcp_developer_token

DB_HOST=cloudsql-socket
DB_UNIX_SOCKET=/cloudsql/hushh-pda-uat:us-central1:hushh-uat-pg
DB_PORT=5432
DB_NAME=postgres
DB_USER=replace_with_uat_db_user
DB_PASSWORD=replace_with_uat_db_password

GOOGLE_API_KEY=replace_with_uat_google_api_key
FINNHUB_API_KEY=
PMP_API_KEY=

CONSENT_SSE_ENABLED=true
SYNC_REMOTE_ENABLED=false
DEVELOPER_API_ENABLED=false
OBS_DATA_STALE_RATIO_THRESHOLD=0.25
ADVISORY_VERIFICATION_BYPASS_ENABLED=true
BROKER_VERIFICATION_BYPASS_ENABLED=true
# Legacy compatibility alias. Prefer ADVISORY_VERIFICATION_BYPASS_ENABLED.
RIA_DEV_BYPASS_ENABLED=true
