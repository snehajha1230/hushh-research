{
  "name": "hushh-webapp",
  "version": "1.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "prepare": "sh -c 'if [ -f ../scripts/setup-hooks.sh ]; then cd .. && sh scripts/setup-hooks.sh; else echo \"Skipping git hooks setup\"; fi'",
    "dev": "node scripts/dev-with-profile.cjs",
    "dev:next": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "node scripts/run-test-ci.cjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:design-system": "node scripts/verify-design-system-usage.cjs",
    "verify:investor-language": "node scripts/verify-investor-language.cjs",
    "verify:docs": "node ../scripts/verify-doc-runtime-parity.cjs",
    "verify:cache": "node scripts/verify-cache-coherence.cjs",
    "verify:css-vars": "node scripts/verify-css-variable-integrity.cjs",
    "verify:routes": "node scripts/verify-route-contracts.cjs",
    "verify:parity": "node scripts/verify-native-parity.cjs",
    "verify:native:browser-compat": "node scripts/verify-native-browser-compat.cjs",
    "verify:capacitor:config": "node scripts/verify-capacitor-runtime-config.cjs",
    "verify:capacitor:routes": "node scripts/verify-capacitor-routes.cjs",
    "verify:capacitor:audit": "node scripts/verify-capacitor-audit.cjs",
    "verify:mobile-firebase": "node scripts/verify-mobile-firebase.cjs",
    "verify:mobile-firebase:release": "npx cross-env REQUIRE_PROD_FIREBASE_ARTIFACTS=true node scripts/verify-mobile-firebase.cjs",
    "verify:capacitor:e2e": "bash scripts/native/verify-capacitor-e2e.sh",
    "inject:mobile-firebase": "bash scripts/inject-mobile-firebase-artifacts.sh",
    "sync:mobile-firebase": "bash scripts/sync-mobile-firebase-artifacts.sh",
    "cap:build": "npm run cap:build:mobile",
    "cap:build:mobile": "npx cross-env CAPACITOR_BUILD=true next build",
    "cap:clean:web": "rm -rf out .next",
    "cap:clean:android": "cd android && ./gradlew clean",
    "cap:clean:ios": "rm -rf ios/App/build ios/App/DerivedData || true",
    "cap:sync:android": "npx cross-env CAPACITOR_PLATFORM=android npx cap sync android",
    "cap:sync:ios": "npx cross-env CAPACITOR_PLATFORM=ios npx cap sync ios",
    "cap:android:run": "bash scripts/native/run-profile.sh --platform android",
    "cap:ios:run": "bash scripts/native/run-profile.sh --platform ios",
    "cap:android:sync": "bash scripts/native/run-profile.sh --platform android --sync-only",
    "cap:ios:sync": "bash scripts/native/run-profile.sh --platform ios --sync-only",
    "cap:sync:android:prod": "npm run cap:sync:android",
    "cap:sync:ios:prod": "npm run cap:sync:ios",
    "cap:android:prod:fresh:run": "bash scripts/native/run-profile.sh --platform android --profile prod-remote --fresh",
    "cap:ios:prod:fresh:run": "bash scripts/native/run-profile.sh --platform ios --profile prod-remote --fresh",
    "cap:ios:prod:sync": "bash scripts/native/run-profile.sh --platform ios --profile prod-remote --sync-only"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@capacitor-firebase/analytics": "^8.0.1",
    "@capacitor-firebase/authentication": "^8.0.1",
    "@capacitor-firebase/messaging": "^8.0.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@material/web": "^2.4.1",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^12.7.0",
    "firebase-admin": "^13.7.0",
    "gsap": "^3.14.2",
    "jose": "^6.1.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.561.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "uc.micro": "^2.1.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^25.0.0",
    "shadcn": "^4.0.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@google-cloud/storage": "7.19.0",
    "@isaacs/brace-expansion": "5.0.1",
    "@tootallnate/once": "3.0.1",
    "@eslint/config-array": {
      "minimatch": "3.1.5"
    },
    "@eslint/eslintrc": {
      "ajv": "6.14.0",
      "minimatch": "3.1.5"
    },
    "eslint": {
      "ajv": "6.14.0",
      "minimatch": "3.1.5"
    },
    "fast-xml-parser": "5.5.5",
    "flatted": "3.4.1",
    "@capacitor/cli": {
      "glob": "13.0.6"
    },
    "glob": {
      "minimatch": "10.2.4"
    },
    "google-gax": "5.0.6",
    "hono": "4.12.8",
    "http-proxy-agent": "7.0.2",
    "retry-request": "8.0.2",
    "tar": "7.5.11",
    "teeny-request": "10.1.0",
    "typescript-eslint": "8.57.0",
    "yauzl": "3.2.1"
  }
}
