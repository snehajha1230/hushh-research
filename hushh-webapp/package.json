{
  "name": "hushh-webapp",
  "version": "1.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "prepare": "cd .. && sh scripts/setup-hooks.sh",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "check-lint": "npm run lint",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:simulate": "npm run typecheck && npm run lint && npm run test && npm run build",
    "verify:routes": "node scripts/verify-route-contracts.cjs",
    "verify:parity": "node scripts/verify-native-parity.cjs",
    "cap:build": "npm run cap:build:mobile",
    "cap:build:mobile": "npx cross-env CAPACITOR_BUILD=true next build",
    "cap:clean:web": "rm -rf out .next",
    "cap:clean:android": "cd android && ./gradlew clean",
    "cap:clean:ios": "rm -rf ios/App/build ios/App/DerivedData || true",
    "cap:sync:android:prod": "npx cross-env CAPACITOR_PLATFORM=android npx cap sync android",
    "cap:sync:ios:prod": "npx cross-env CAPACITOR_PLATFORM=ios npx cap sync ios",
    "cap:android:prod:fresh:run": "npm run cap:clean:web && npm run cap:clean:android && npm run cap:build:mobile && npm run cap:sync:android:prod && npx cap run android --target Pixel_9_Pro",
    "cap:ios:prod:fresh:run": "npm run cap:clean:web && npm run cap:clean:ios && npm run cap:build:mobile && npm run cap:sync:ios:prod && npx cap run ios",
    "cap:ios:prod:sync": "npm run cap:build:mobile && npm run cap:sync:ios:prod"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@capacitor-firebase/authentication": "^8.0.1",
    "@capacitor-firebase/messaging": "^8.0.1",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@material/web": "^2.4.1",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "firebase": "^12.7.0",
    "firebase-admin": "^13.6.0",
    "gsap": "^3.14.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.561.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "uc.micro": "^2.1.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^2.0.0"
  },
  "overrides": {
    "tar": "7.5.7",
    "@isaacs/brace-expansion": "5.0.1"
  }
}
