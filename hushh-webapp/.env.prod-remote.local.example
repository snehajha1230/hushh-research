# Frontend runtime profile: prod-remote
# Local frontend pointed at deployed production backend.

APP_RUNTIME_PROFILE=prod-remote
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_BACKEND_URL=https://consent-protocol-1006304528804.us-central1.run.app
NEXT_PUBLIC_APP_URL=https://kai.hushh.ai
NEXT_PUBLIC_FRONTEND_URL=https://kai.hushh.ai

NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_prod_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_with_prod_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace_with_prod_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_with_prod_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_prod_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_prod_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=replace_with_prod_vapid_key

NEXT_PUBLIC_AUTH_FIREBASE_API_KEY=replace_with_same_shared_firebase_api_key_if_used
NEXT_PUBLIC_AUTH_FIREBASE_AUTH_DOMAIN=replace_with_same_shared_firebase_auth_domain_if_used
NEXT_PUBLIC_AUTH_FIREBASE_PROJECT_ID=replace_with_same_shared_firebase_project_id_if_used
NEXT_PUBLIC_AUTH_FIREBASE_APP_ID=replace_with_same_shared_firebase_app_id_if_used

FIREBASE_SERVICE_ACCOUNT_JSON=replace_with_prod_service_account_json
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=replace_with_same_shared_firebase_service_account_json_if_used

NEXT_PUBLIC_OBSERVABILITY_ENABLED=true
NEXT_PUBLIC_OBSERVABILITY_DEBUG=false
NEXT_PUBLIC_OBSERVABILITY_SAMPLE_RATE=1
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_UAT=replace_with_uat_measurement_id_if_needed
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_STAGING=replace_with_uat_measurement_id_if_needed
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_PRODUCTION=replace_with_prod_measurement_id
NEXT_PUBLIC_GTM_ID_UAT=replace_with_uat_gtm_id_if_needed
NEXT_PUBLIC_GTM_ID_STAGING=replace_with_uat_gtm_id_if_needed
NEXT_PUBLIC_GTM_ID_PRODUCTION=replace_with_prod_gtm_id
