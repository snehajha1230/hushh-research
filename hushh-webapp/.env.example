# Frontend Environment Variables
# Copy to .env.local and fill in values. See docs/reference/operations/env-and-secrets.md.
# Runtime profile workflow:
# - Bootstrap local runtime profile files from templates + cloud secrets:
#   bash ../scripts/env/bootstrap_profiles.sh
# - Canonical source files:
#   .env.local-uatdb.local / .env.uat-remote.local / .env.prod-remote.local
# - Activate profile:
#   bash ../scripts/env/use_profile.sh local-uatdb|uat-remote|prod-remote

# ============================================================================
# FIREBASE (required for auth)
# ============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# Optional auth-only override (useful for UAT web login against prod Firebase Auth).
# If unset, auth uses NEXT_PUBLIC_FIREBASE_* values above.
NEXT_PUBLIC_AUTH_FIREBASE_API_KEY=
NEXT_PUBLIC_AUTH_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_AUTH_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_AUTH_FIREBASE_APP_ID=
# Optional for analytics linkage (uat/prod split)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_UAT=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_STAGING=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_PRODUCTION=
# Optional direct override (takes precedence over env-split vars)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ============================================================================
# BACKEND
# ============================================================================
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# Optional but recommended for native passkey RP inference when
# NEXT_PUBLIC_PASSKEY_RP_ID is not explicitly set.
# NEXT_PUBLIC_APP_URL=https://your-frontend-domain.example
# NEXT_PUBLIC_FRONTEND_URL=https://your-frontend-domain.example

# ============================================================================
# PASSKEY / DOMAIN ASSOCIATION
# ============================================================================
# Optional explicit RP ID for passkeys.
# - Web: leave unset to use host-based RP ID.
# - Native iOS/Android: set explicitly if you use a custom domain.
# - Keep unset if you want localhost + hosted dual-domain enrollment.
# NEXT_PUBLIC_PASSKEY_RP_ID=your-frontend-domain.example

# iOS associated app identifier = <APPLE_TEAM_ID>.<NEXT_PUBLIC_IOS_BUNDLE_ID>
NEXT_PUBLIC_IOS_BUNDLE_ID=com.hushh.app
# APPLE_TEAM_ID=ABCDE12345
# NEXT_PUBLIC_APPLE_TEAM_ID=ABCDE12345

# Android Digital Asset Links
NEXT_PUBLIC_ANDROID_APP_ID=com.hushh.app
# Comma-separated SHA-256 cert fingerprints for signing certs
# ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:...:ZZ,11:22:...

# ============================================================================
# BUILD / RUNTIME
# ============================================================================
# CAPACITOR_BUILD is set by npm run cap:build
NEXT_PUBLIC_APP_ENV=development
# NODE_ENV is set by Next.js

# ============================================================================
# OBSERVABILITY (GA4 + GTM + Firebase Analytics)
# ============================================================================
# Optional legacy fallback keys still accepted for one release cycle:
# NEXT_PUBLIC_OBSERVABILITY_ENV=uat
# NEXT_PUBLIC_ENVIRONMENT_MODE=development
NEXT_PUBLIC_OBSERVABILITY_ENABLED=true
NEXT_PUBLIC_OBSERVABILITY_DEBUG=false
# 0.0 - 1.0 sampling for event emission
NEXT_PUBLIC_OBSERVABILITY_SAMPLE_RATE=1
# GTM container IDs per environment
NEXT_PUBLIC_GTM_ID_UAT=
NEXT_PUBLIC_GTM_ID_STAGING=
NEXT_PUBLIC_GTM_ID_PRODUCTION=
# Optional direct override for GTM container ID
# NEXT_PUBLIC_GTM_ID=

# ============================================================================
# OPTIONAL (server-side only; do not prefix with NEXT_PUBLIC_)
# ============================================================================
# Used by Next.js server routes for Firebase ID token verification.
# Prefer auth-specific credential for auth-split (UAT web using prod Firebase Auth).
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=
# SESSION_SECRET=     # If using session API
# BACKEND_URL=        # Server-side fallback
# NEXT_PUBLIC_CONSENT_TIMEOUT_SECONDS=120
# NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ============================================================================
# APP REVIEW MODE
# ============================================================================
# App review config is now served by backend runtime endpoint:
# GET /api/app-config/review-mode
