{
  "version": 1,
  "nativeSupportedPageContractIds": [
    "homePage",
    "loginPage",
    "profileAppearanceLabPage",
    "kaiHomePage",
    "kaiOnboardingPage",
    "kaiImportPage",
    "kaiDashboardPage",
    "kaiInvestmentsPage",
    "kaiDashboardLegacyRedirectPage",
    "kaiAnalysisPage",
    "kaiOptimizePage",
    "kaiPlaidOauthReturnPage",
    "consentsPage",
    "developersPage",
    "profilePage",
    "marketplacePage",
    "marketplaceRiaProfilePage",
    "riaHomePage",
    "riaOnboardingPage",
    "riaClientsPage",
    "riaRequestsPage",
    "riaPicksPage",
    "riaWorkspacePage",
    "riaSettingsPage",
    "logoutPage",
    "legacyAnalysisRedirectPage"
  ],
  "webOnlyExemptPageContractIds": [],
  "acceptedParityExceptions": [
    {
      "id": "androidPasskeyPrfPending",
      "status": "accepted_exception",
      "summary": "Android native passkey PRF methods are not shipped yet; iOS PRF is implemented and biometric/passphrase fallback remains active on Android.",
      "docPaths": [
        "docs/guides/mobile.md"
      ]
    },
    {
      "id": "cloudBackedVaultPreferenceMethods",
      "status": "accepted_exception",
      "summary": "Some vault preference flows remain cloud-backed or intentionally unsupported in the web/native fallback surface, and must use documented cloud-backed paths instead of local-only native methods.",
      "docPaths": [
        "docs/guides/mobile.md"
      ]
    }
  ],
  "browserCompat": {
    "allowedDirectUsage": {
      "clipboard_write": [
        "hushh-webapp/lib/utils/clipboard.ts"
      ],
      "navigation_mutation": [
        "hushh-webapp/lib/utils/browser-navigation.ts"
      ],
      "window_open": [
        "hushh-webapp/lib/utils/browser-navigation.ts"
      ],
      "local_storage": [
        "hushh-webapp/lib/utils/session-storage.ts",
        "hushh-webapp/lib/capacitor/plugins/settings-web.ts"
      ],
      "session_storage": [
        "hushh-webapp/lib/utils/session-storage.ts"
      ],
      "indexed_db": [
        "hushh-webapp/lib/notifications/fcm-service.ts",
        "hushh-webapp/lib/capacitor/plugins/database-web.ts"
      ],
      "blob_export": [
        "hushh-webapp/lib/utils/native-download.ts",
        "hushh-webapp/lib/capacitor/plugins/kai-web.ts"
      ],
      "file_reader": [
        "hushh-webapp/lib/services/api-service.ts"
      ]
    }
  }
}
