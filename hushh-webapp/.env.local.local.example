# Frontend runtime mode: local
# Local frontend + local backend, while the database/runtime stays on UAT.
# Firebase identity stays on the shared app project.

APP_RUNTIME_MODE=local
APP_RUNTIME_PROFILE=local
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_shared_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_with_shared_firebase_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace_with_shared_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_with_shared_firebase_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_shared_firebase_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_shared_firebase_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=replace_with_shared_firebase_vapid_key

NEXT_PUBLIC_AUTH_FIREBASE_API_KEY=replace_with_same_shared_firebase_api_key_if_used
NEXT_PUBLIC_AUTH_FIREBASE_AUTH_DOMAIN=replace_with_same_shared_firebase_auth_domain_if_used
NEXT_PUBLIC_AUTH_FIREBASE_PROJECT_ID=replace_with_same_shared_firebase_project_id_if_used
NEXT_PUBLIC_AUTH_FIREBASE_APP_ID=replace_with_same_shared_firebase_app_id_if_used

FIREBASE_SERVICE_ACCOUNT_JSON=replace_with_shared_firebase_service_account_json
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=replace_with_same_shared_firebase_service_account_json_if_used

NEXT_PUBLIC_OBSERVABILITY_ENABLED=true
NEXT_PUBLIC_OBSERVABILITY_DEBUG=false
NEXT_PUBLIC_OBSERVABILITY_SAMPLE_RATE=1
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_UAT=replace_with_uat_measurement_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_STAGING=replace_with_uat_measurement_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_PRODUCTION=replace_with_prod_measurement_id_if_needed
NEXT_PUBLIC_GTM_ID_UAT=replace_with_uat_gtm_id
NEXT_PUBLIC_GTM_ID_STAGING=replace_with_uat_gtm_id
NEXT_PUBLIC_GTM_ID_PRODUCTION=replace_with_prod_gtm_id_if_needed

# Optional PKM migration drill user id for local tooling
NEXT_PUBLIC_KAI_TEST_USER_ID=replace_with_test_user_id
# Optional local/UAT-only no-write PKM rehearsal for the Kai test user
NEXT_PUBLIC_PKM_UPGRADE_REHEARSAL=false

# Native local artifacts and signing
IOS_GOOGLESERVICE_INFO_PLIST_B64=replace_with_ios_plist_b64_if_native_builds_are_needed
ANDROID_GOOGLE_SERVICES_JSON_B64=replace_with_android_google_services_b64_if_native_builds_are_needed
APPLE_TEAM_ID=replace_with_apple_team_id_if_ios_builds_are_needed
IOS_DEV_CERT_P12_B64=replace_with_ios_dev_cert_b64_if_ios_builds_are_needed
IOS_DEV_CERT_PASSWORD=replace_with_ios_dev_cert_password_if_ios_builds_are_needed
IOS_DEV_PROFILE_B64=replace_with_ios_dev_profile_b64_if_ios_builds_are_needed
IOS_DIST_CERT_P12_B64=replace_with_ios_dist_cert_b64_if_ios_builds_are_needed
IOS_DIST_CERT_PASSWORD=replace_with_ios_dist_cert_password_if_ios_builds_are_needed
IOS_APPSTORE_PROFILE_B64=replace_with_ios_distribution_profile_b64_if_ios_builds_are_needed
APPSTORE_CONNECT_API_KEY_P8_B64=replace_with_appstore_connect_p8_b64_if_ios_builds_are_needed
APPSTORE_CONNECT_KEY_ID=replace_with_appstore_connect_key_id_if_ios_builds_are_needed
APPSTORE_CONNECT_ISSUER_ID=replace_with_appstore_connect_issuer_id_if_ios_builds_are_needed
ANDROID_RELEASE_KEYSTORE_B64=replace_with_android_keystore_b64_if_local_release_builds_are_needed
ANDROID_RELEASE_KEYSTORE_PASSWORD=replace_with_android_keystore_password_if_local_release_builds_are_needed
ANDROID_RELEASE_KEY_ALIAS=replace_with_android_key_alias_if_local_release_builds_are_needed
ANDROID_RELEASE_KEY_PASSWORD=replace_with_android_key_password_if_local_release_builds_are_needed

# Voice / Realtime
NEXT_PUBLIC_FORCE_REALTIME_VOICE=true
NEXT_PUBLIC_FAIL_FAST_VOICE=true
NEXT_PUBLIC_DISABLE_VOICE_FALLBACKS=true
NEXT_PUBLIC_VOICE_V2_TTS_BACKEND_FALLBACK_ENABLED=false
