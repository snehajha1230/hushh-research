{
  "name": "@hushh/mcp",
  "version": "0.1.2",
  "description": "Launch-friendly npm wrapper for the Hushh Consent MCP server",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hushh-labs/hushh-research.git",
    "directory": "packages/hushh-mcp"
  },
  "homepage": "https://github.com/hushh-labs/hushh-research/tree/main/packages/hushh-mcp",
  "bugs": {
    "url": "https://github.com/hushh-labs/hushh-research/issues"
  },
  "bin": {
    "hushh-mcp": "bin/hushh-mcp.js"
  },
  "files": [
    "README.md",
    "bin/",
    "public-docs.json",
    "scripts/",
    "vendor/"
  ],
  "scripts": {
    "docs:render": "node ./scripts/render-readme.mjs",
    "docs:check": "node ./scripts/render-readme.mjs --check",
    "prepack": "node ./scripts/stage-runtime.mjs",
    "print-config": "node ./bin/hushh-mcp.js --print-config",
    "print-codex-toml": "node ./bin/hushh-mcp.js --print-codex-toml",
    "print-remote-config": "node ./bin/hushh-mcp.js --print-remote-config"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.18"
  }
}
