# Backend runtime profile: prod-remote
# Reference-only local copy of deployed production backend config. Not launched by default.

APP_RUNTIME_PROFILE=prod-remote
ENVIRONMENT=production
PORT=8000
FRONTEND_URL=https://kai.hushh.ai
CORS_ALLOWED_ORIGINS=https://kai.hushh.ai
PLAID_ENV=production
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_CLIENT_NAME=Hushh Kai
PLAID_COUNTRY_CODES=US
PLAID_WEBHOOK_URL=https://kai.hushh.ai/api/kai/plaid/webhook
PLAID_REDIRECT_PATH=/kai/plaid/oauth/return
PLAID_TOKEN_ENCRYPTION_KEY=
PLAID_TX_HISTORY_DAYS=730
GOOGLE_GENAI_USE_VERTEXAI=True
OTEL_ENABLED=true

SECRET_KEY=
VAULT_ENCRYPTION_KEY=__SET_VAULT_KEY__
FIREBASE_SERVICE_ACCOUNT_JSON=__FIREBASE_SERVICE_ACCOUNT_JSON__
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=__FIREBASE_AUTH_SERVICE_ACCOUNT_JSON__
APP_REVIEW_MODE=false
REVIEWER_UID=replace_with_reviewer_uid_if_used
# Optional: self-serve developer token for stdio MCP and token-auth lookups.
HUSHH_DEVELOPER_TOKEN=

DB_HOST=replace_with_prod_db_host
DB_PORT=5432
DB_NAME=postgres
DB_USER=replace_with_prod_db_user
DB_PASSWORD=replace_with_prod_db_password

GOOGLE_API_KEY=
FINNHUB_API_KEY=
PMP_API_KEY=

CONSENT_SSE_ENABLED=false
SYNC_REMOTE_ENABLED=false
DEVELOPER_API_ENABLED=false
REMOTE_MCP_ENABLED=false
OBS_DATA_STALE_RATIO_THRESHOLD=0.25
ADVISORY_VERIFICATION_BYPASS_ENABLED=false
BROKER_VERIFICATION_BYPASS_ENABLED=false
# Legacy compatibility alias. Prefer ADVISORY_VERIFICATION_BYPASS_ENABLED.
RIA_DEV_BYPASS_ENABLED=false
