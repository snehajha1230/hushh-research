{
  "id": "mobile-native",
  "role": "owner",
  "owner_family": "mobile-native",
  "primary_scope": "mobile-native-intake",
  "description": "Use when the request is broadly about iOS, Android, Capacitor plugins, or native parity and the correct mobile specialist skill is not yet clear.",
  "owned_paths": [
    "hushh-webapp/ios",
    "hushh-webapp/android"
  ],
  "non_owned_paths": [
    "frontend",
    "backend",
    "docs-governance"
  ],
  "task_types": [
    "mobile-parity-check",
    "new-feature-tri-flow",
    "release-readiness"
  ],
  "required_reads": [
    "docs/reference/mobile/README.md",
    "docs/guides/new-feature.md",
    "hushh-webapp/ios/App/CapApp-SPM/README.md"
  ],
  "required_commands": [
    "cd hushh-webapp && npm run typecheck",
    "cd hushh-webapp && npm run cap:build"
  ],
  "verification_bundles": [
    {
      "id": "mobile-native-core",
      "commands": [
        "cd hushh-webapp && npm run typecheck",
        "cd hushh-webapp && npm run cap:build"
      ],
      "tests": [
        "cd hushh-webapp && npm run typecheck"
      ]
    }
  ],
  "handoff_targets": [
    "mobile-plugin-contracts",
    "mobile-parity-audit",
    "repo-context",
    "frontend"
  ],
  "adjacent_skills": [
    "mobile-plugin-contracts",
    "mobile-parity-audit",
    "frontend",
    "quality-contracts"
  ],
  "risk_tags": [
    "native-parity-drift",
    "plugin-contract-drift",
    "release-readiness-drift"
  ]
}
