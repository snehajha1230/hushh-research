{
  "id": "ci-watch-and-heal",
  "title": "CI Watch And Heal",
  "goal": "Monitor PR, merge-queue, and post-merge smoke checks live, classify failures into the correct owner skill, pull the failing job logs, and keep the fix-and-rerun loop tight until CI reaches a terminal state or a hard blocker is identified.",
  "owner_skill": "repo-operations",
  "default_spoke": null,
  "task_type": "ci-watch-and-heal",
  "affected_surfaces": [
    "bin",
    "scripts",
    ".github/workflows",
    "docs/reference/operations",
    "hushh-webapp",
    "consent-protocol"
  ],
  "required_reads": [
    "docs/reference/operations/ci.md",
    "docs/reference/quality/pr-impact-checklist.md",
    ".codex/skills/repo-operations/references/agent-trigger-policy.md"
  ],
  "required_commands": [
    "./bin/hushh codex route-task ci-watch-and-heal",
    "./bin/hushh codex ci-status --watch",
    "./bin/hushh ci --include-advisory"
  ],
  "verification_bundle": {
    "id": "ci-watch-and-heal",
    "commands": [
      "./bin/hushh ci --include-advisory",
      "./bin/hushh codex ci-status"
    ],
    "tests": [
      "./bin/hushh ci --include-advisory"
    ]
  },
  "deliverables": [
    "live check-state summary",
    "delivery stage classification",
    "failing job classification",
    "fix-and-rerun log",
    "terminal CI outcome or blocker note"
  ],
  "impact_fields": [
    "Failing checks",
    "Delivery stage",
    "Owner skill selected",
    "Docs updated",
    "Verification commands executed"
  ],
  "handoff_chain": [
    "repo-operations",
    "frontend",
    "backend",
    "quality-contracts",
    "docs-governance",
    "security-audit"
  ],
  "common_failures": [
    "treating a red check as someone else's problem",
    "not routing the failed job to the correct owner skill",
    "not distinguishing PR feedback from queue authority or post-merge deploy authority",
    "stopping after rerun without monitoring terminal state"
  ]
}
